# Database Configuration
DB_HOST=localhost
DB_NAME=scorecard_db
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_PORT=3306

# Application Configuration
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# Session Configuration
SESSION_LIFETIME_HOURS=24
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Email Configuration (Optional - See EMAIL_SETUP_GUIDE.md for setup instructions)
# Set EMAIL_VERIFICATION_ENABLED=False to skip email verification during development
EMAIL_VERIFICATION_ENABLED=True
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
FROM_EMAIL=your-email@gmail.com
FROM_NAME=Cricket Scorecard

# Application
FLASK_ENV=development
FLASK_DEBUG=True
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Fantasy Cricket - CricketData.org API
CRICKETDATA_API_KEY=your-cricketdata-api-key-here
FANTASY_IPL_SERIES_ID=87c62aac-bc3c-4738-ab93-19da0690488f
